{
  "name": "bridge-api-fhir",
  "version": "2.0.0",
  "description": "Bridge API for FHIR Clinical History Interoperability - MinSalud Colombia",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "migrate": "node dist/database/migrations/index.js",
    "seed": "node dist/database/seeds/index.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "FHIR",
    "Healthcare",
    "API",
    "MinSalud",
    "Colombia"
  ],
  "author": "MinSalud Colombia",
  "license": "Apache-2.0",
  "dependencies": {
    "axios": "^1.5.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "fhir": "^3.3.1",
    "helmet": "^7.0.0",
    "joi": "^17.10.0",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.29.4",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "pg": "^8.20.0",
    "redis": "^4.6.10",
    "uuid": "^9.0.1",
    "winston": "^3.10.0"
